# Используем Node.js (версия 20, как в твоем проекте)
FROM node:20-alpine

# Указываем рабочую директорию
WORKDIR /app

# Копируем файлы манифеста для установки зависимостей
COPY package*.json ./

# Устанавливаем зависимости
RUN npm install

# Копируем все остальные файлы
COPY . .

# Открываем порт, на котором работает Vite
EXPOSE 5173

# Запускаем в режиме разработки с флагом --host 
# Это нужно, чтобы Vite принимал запросы извне контейнера
CMD ["npm", "run", "dev", "--", "--host"]